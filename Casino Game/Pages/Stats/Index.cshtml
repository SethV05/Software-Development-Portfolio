@page
@model SVassey_FinalProject_CPT206_A80H.Pages.Stats.IndexModel

@{
    ViewData["Title"] = "Stats";
}

<div class="center-screen">
    <div class="card-box stats-box">

        <h1>Player Stats</h1>

        <div class="stats-grid">
            <div class="stat-card">
                <h3>Total Games</h3>
                <p>@Model.TotalGames</p>
            </div>

            <div class="stat-card">
                <h3>Wins</h3>
                <p>@Model.Wins</p>
            </div>

            <div class="stat-card">
                <h3>Losses</h3>
                <p>@Model.Losses</p>
            </div>

            <div class="stat-card">
                <h3>Pushes</h3>
                <p>@Model.Pushes</p>
            </div>

            <div class="stat-card">
                <h3>Win %</h3>
                <p>@Model.WinPercentage%</p>
            </div>

            <div class="stat-card">
                <h3>Total Bet</h3>
                <p>$@Model.TotalBet.ToString("0.00")</p>
            </div>

            <div class="stat-card">
                <h3>Profit / Loss</h3>
                <p>$@Model.ProfitLoss.ToString("0.00")</p>
            </div>
        </div>

        <h2>Recent Games</h2>

        <table class="stats-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Bet</th>
                    <th>Result</th>
                    <th>Before</th>
                    <th>After</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var game in Model.RecentGames)
                {
                    <tr>
                        <td>@game.PlayedAt.ToShortDateString()</td>
                        <td>$@game.BetAmount.ToString("0.00")</td>
                        <td>@game.Result</td>
                        <td>$@game.BalanceBefore.ToString("0.00")</td>
                        <td>$@game.BalanceAfter.ToString("0.00")</td>
                    </tr>
                }
            </tbody>
        </table>

        <a class="big-button" asp-page="/Game/Index">Back to Blackjack</a>

    </div>
</div>